# Linear search with while
def linear_search(list, target):
    i=0
    while i < len(list):
        if list[i] == target:
            return i
        i += 1
    return -1
list = [1, 2, 3, 4, 5]
target = int(input("Enter the target number: "))
index = linear_search(list, target)
print("Element found at index:", index)



